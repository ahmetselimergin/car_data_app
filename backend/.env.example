# Postgres bağlantısı — Neon, Docker veya yerel kurulum farketmez
DATABASE_URL=postgres://user:pass@localhost:5432/cardex

PORT=4000
# Virgülle birden fazla origin: admin Next.js
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# Firebase Admin (kullanıcı yönetimi için). Boş bırakılırsa /firebase-users 503 döner.
# Console → Project settings → Service accounts → Generate new private key
# İndirdiğin JSON dosyasını backend/ altına koy.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
